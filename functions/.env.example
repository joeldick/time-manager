# Environment variables for Time Manager Cloud Functions
# Copy this file to .env.local and fill in your actual values
# Do NOT commit .env.local or any file with real credentials to version control

# Support email address where contact form submissions will be sent
SUPPORT_EMAIL=your-support@example.com

# Gmail configuration for sending emails via contact form
# Use a Gmail app-specific password (https://support.google.com/accounts/answer/185833)
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=your-app-specific-password
